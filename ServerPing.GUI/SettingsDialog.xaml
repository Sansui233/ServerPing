<Window x:Class="ServerPing.GUI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="350" Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="设置" FontSize="13" FontWeight="SemiBold" Margin="14,0,0,0" />
                <Button Grid.Column="1" Style="{StaticResource TitleBarCloseButton}"
                        Width="38" Height="38" Click="Close_Click">
                    <Path Data="{StaticResource Icon.X}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="13" Height="13" Stretch="Uniform" />
                </Button>
            </Grid>

            <!-- Content -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" Padding="18,16,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                <TextBlock Text="监控" FontWeight="SemiBold" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ping 间隔（秒）" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="PingIntervalTextBox" Margin="16,0,16,0"/>
                </Grid>

                

                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="失败次数" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="FailureThresholdTextBox"  Margin="16,0,16,0"/>
                </Grid>


                <TextBlock Text="UI" FontWeight="SemiBold" Margin="0,16,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="后台运行时UI休眠时长（秒）" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="HibernateDurationTextBox" Margin="16,0,16,0"/>
                </Grid>

                <CheckBox x:Name="SilentStartupCheckBox"
                          Content="静默启动，不自动打开管理面板"
                          Margin="0,4,0,18" />

                <TextBlock Text="数据目录" FontWeight="SemiBold" Margin="0,16,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DockPanel LastChildFill="True" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Folder}"
                              Stroke="{DynamicResource MutedTextBrush}"
                              StrokeThickness="1.7" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="16" Height="16" Stretch="Uniform"
                              Margin="0,0,7,0" DockPanel.Dock="Left" />
                        <TextBlock x:Name="DataDirectoryTextBlock"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <Button Grid.Column="1" Content="打开" Padding="12,5"
                            Click="OpenDataDirectory_Click" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Margin="10,0,0,0" />
                </Grid>

                <!-- Test notification — no wrapping border -->
                <Grid Margin="0,16,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="测试通知" FontWeight="SemiBold" />
                        <TextBlock Text="发送一条 Windows Toast 测试消息"
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="测试" Padding="12,5"
                            Click="TestNotification_Click" VerticalAlignment="Center" />
                </Grid>

                <TextBlock x:Name="MessageTextBlock"
                           Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}" BorderThickness="0,1,0,0"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Padding="16,5" Margin="0,0,8,0" Click="Close_Click" />
                    <Button Content="保存" Padding="16,5"
                            Background="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Click="Save_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
