<Window x:Class="ServerPing.GUI.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="从 Terminal 导入" Height="400" Width="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="从 Windows Terminal 导入 SSH Profile"
                           FontSize="13" FontWeight="SemiBold" Margin="14,0,0,0" />
                <Button Grid.Column="1" Style="{StaticResource TitleBarCloseButton}"
                        Width="38" Height="38" Click="Cancel_Click">
                    <Path Data="{StaticResource Icon.X}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="13" Height="13" Stretch="Uniform" />
                </Button>
            </Grid>

            <!-- Profile list -->
            <DataGrid Grid.Row="1" x:Name="ProfileGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="38"
                      AlternationCount="2"
                      HeadersVisibility="Column"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="36" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="名称"    Binding="{Binding Name}"        Width="Auto" MinWidth="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="主机"    Binding="{Binding Host}"        Width="Auto" MinWidth="130" IsReadOnly="True" />
                    <DataGridTextColumn Header="命令"    Binding="{Binding CommandLine}" Width="*"    IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Footer -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource PanelBackgroundBrush}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="全选"  Click="SelectAll_Click"  Padding="12,4" Margin="0,0,6,0" />
                        <Button Content="全不选" Click="SelectNone_Click" Padding="12,4" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="导入" Padding="18,5" Margin="0,0,8,0"
                                Background="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Click="Import_Click" IsDefault="True" />
                        <Button Content="取消" Padding="18,5" Click="Cancel_Click" IsCancel="True" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
