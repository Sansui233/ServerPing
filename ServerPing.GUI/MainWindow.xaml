<Window x:Class="ServerPing.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ServerPing.GUI.ViewModels"
        Title="ServerPing"
        Height="560" Width="980"
        MinHeight="440" MinWidth="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="4" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border Background="{StaticResource AppBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="8" Height="8" Background="{StaticResource AccentBrush}" CornerRadius="4" Margin="0,0,9,0" />
                    <TextBlock Text="ServerPing" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>

                <!-- Import from Terminal -->
                <Button Grid.Column="1" Style="{StaticResource TitleBarIconButton}"
                        Width="38" Height="38" ToolTip="从 Terminal 导入"
                        Command="{Binding ImportFromTerminalCommand}">
                    <Path Data="{StaticResource Icon.Terminal}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="15" Height="15" Stretch="Uniform" />
                </Button>

                <!-- Settings -->
                <Button Grid.Column="2" Style="{StaticResource TitleBarIconButton}"
                        Width="38" Height="38" ToolTip="设置"
                        Click="Settings_Click">
                    <Path Data="{StaticResource Icon.Settings}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="15" Height="15" Stretch="Uniform" />
                </Button>

                <!-- Minimize -->
                <Button Grid.Column="3" Style="{StaticResource TitleBarIconButton}"
                        Width="38" Height="38" ToolTip="最小化"
                        Click="Minimize_Click">
                    <Path Data="{StaticResource Icon.Minus}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="14" Height="14" Stretch="Uniform" />
                </Button>

                <!-- Close -->
                <Button Grid.Column="4" Style="{StaticResource TitleBarCloseButton}"
                        Width="38" Height="38" ToolTip="关闭"
                        Click="Close_Click">
                    <Path Data="{StaticResource Icon.X}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="13" Height="13" Stretch="Uniform" />
                </Button>
            </Grid>

            <!-- Server list -->
            <DataGrid Grid.Row="1"
                      x:Name="ServerDataGrid"
                      ItemsSource="{Binding Servers}"
                      SelectedItem="{Binding SelectedServer}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeight="38"
                      AlternationCount="2"
                      Margin="0">

                <DataGrid.Columns>
                    <!-- Name: editable TextBox -->
                    <DataGridTemplateColumn Header="名称" Width="Auto" MinWidth="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="NameTextBox_LostFocus"
                                         KeyDown="NameTextBox_KeyDown"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="4,0"
                                         VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Host: editable TextBox -->
                    <DataGridTemplateColumn Header="Host / IP" Width="Auto" MinWidth="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="HostTextBox_LostFocus"
                                         KeyDown="HostTextBox_KeyDown"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="4,0"
                                         VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status -->
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="Auto" MinWidth="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusText}" Value="在线">
                                        <Setter Property="Foreground" Value="#34D399" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="离线">
                                        <Setter Property="Foreground" Value="#F87171" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusText}" Value="未知">
                                        <Setter Property="Foreground" Value="#94A3B8" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Last check -->
                    <DataGridTextColumn Header="最后检查" Binding="{Binding LastPingTimeText}" Width="Auto" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Enabled -->
                    <DataGridTemplateColumn Header="启用" Width="Auto" MinWidth="52">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsHitTestVisible="False" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 1h stats -->
                    <DataGridTextColumn Header="1h 成/败/总" Binding="{Binding LastHourStatsText}" Width="Auto" MinWidth="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 1d stats -->
                    <DataGridTextColumn Header="1d 成/败/总" Binding="{Binding LastDayStatsText}" Width="Auto" MinWidth="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 1h availability -->
                    <DataGridTextColumn Header="1h 可用率" Binding="{Binding LastHourAvailabilityText}" Width="Auto" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="操作" Width="*" MinWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="{Binding IsEnabled, Converter={StaticResource EnableToggleConverter}}"
                                            Command="{Binding DataContext.ToggleServerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Padding="8,3" Margin="0,0,6,0" />
                                    <Button Command="{Binding DataContext.RemoveServerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Padding="6,3"
                                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                            ToolTip="删除">
                                        <Path Data="{StaticResource Icon.Trash}"
                                              Stroke="{StaticResource DangerBrush}"
                                              StrokeThickness="1.4" StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="14" Height="14" Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Add row button: full width, appears below the list -->
            <Button Grid.Row="2" Style="{StaticResource AddRowButton}"
                    Command="{Binding AddServerCommand}"
                    ToolTip="添加服务器">
                <Path Data="{StaticResource Icon.Plus}"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.6" StrokeLineJoin="Round"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Width="16" Height="16" Stretch="Uniform" />
            </Button>

            <!-- Status bar -->
            <Border Grid.Row="3" Padding="14,6" Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
            </Border>
        </Grid>
    </Border>
</Window>
