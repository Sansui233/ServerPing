<Window x:Class="ServerPing.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ServerPing.GUI.ViewModels"
        xmlns:serverList="clr-namespace:ServerPing.GUI.Views.ServerList"
        xmlns:statsOverlay="clr-namespace:ServerPing.GUI.Views.ServerStatsOverlay"
        Title="ServerPing"
        MinHeight="310" MaxHeight="560" MaxWidth="600"
        SizeToContent="Height"
        Icon="Assets/App.Ico/Icon-tray_128x128.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
            <Grid Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="8" Height="8" Background="{DynamicResource AccentBrush}" CornerRadius="4" Margin="0,0,9,0" />
                    <TextBlock Text="ServerPing" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>

                <!-- Undo -->
                <Button Grid.Column="1" Style="{StaticResource TitleBarIconButton}"
                        Height="38" Padding="10,0"
                        Command="{Binding UndoDeleteCommand}"
                        Visibility="{Binding CanUndo, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Undo}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="14" Height="14" Stretch="Uniform" />
                        <TextBlock Text="{DynamicResource Main.Undo}" Margin="5,0,0,0" FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>

                <!-- Add -->
                <Button Grid.Column="2" Style="{StaticResource TitleBarIconButton}"
                        Height="38" Padding="10,0"
                        Command="{Binding AddServerCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Plus}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="14" Height="14" Stretch="Uniform" />
                        <TextBlock Text="{DynamicResource Main.Add}" Margin="5,0,0,0" FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>

                <!-- Import -->
                <Button Grid.Column="3" Style="{StaticResource TitleBarIconButton}"
                        Height="38" Padding="10,0" ToolTip="{DynamicResource Main.ImportTooltip}"
                        Command="{Binding ImportFromTerminalCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Import}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="14" Height="14" Stretch="Uniform" />
                        <TextBlock Text="{DynamicResource Main.Import}" Margin="5,0,0,0" FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>

                <!-- Settings -->
                <Button Grid.Column="4" Style="{StaticResource TitleBarIconButton}"
                        Height="38" Padding="10,0"
                        Click="Settings_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Settings}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="14" Height="14" Stretch="Uniform" />
                        <TextBlock Text="{DynamicResource Main.Settings}" Margin="5,0,0,0" FontSize="12"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>

                <!-- Minimize -->
                <Button Grid.Column="5" Style="{StaticResource TitleBarIconButton}"
                        Width="38" Height="38" ToolTip="{DynamicResource Main.Minimize}" Click="Minimize_Click">
                    <Path Data="{StaticResource Icon.Minus}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="14" Height="14" Stretch="Uniform" />
                </Button>

                <!-- Close -->
                <Button Grid.Column="6" Style="{StaticResource TitleBarCloseButton}" Margin="0,0,2,0"
                        Width="38" Height="38" ToolTip="{DynamicResource Main.Close}" Click="Close_Click">
                    <Path Data="{StaticResource Icon.X}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="13" Height="13" Stretch="Uniform" />
                </Button>
            </Grid>
            </Border>

            <Grid Grid.Row="1">
                <serverList:ServerListView x:Name="ServerList" />
                <statsOverlay:ServerStatsOverlayView DataContext="{Binding SelectedStatsOverlay}"
                                                     Visibility="{Binding DataContext.IsStatsOverlayVisible,
                                                                          RelativeSource={RelativeSource AncestorType=Window},
                                                                          Converter={StaticResource BoolToVis}}" />
            </Grid>

        </Grid>
    </Border>
</Window>
