<UserControl x:Class="ServerPing.GUI.Views.ServerStatsOverlay.ServerStatsOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="OverlayBackButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OverlayHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OverlayHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource AppBackgroundBrush}">
        <Grid Margin="16,12,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,6">
                <Button Width="30" Height="30" Padding="0"
                        Style="{StaticResource OverlayBackButton}"
                        DockPanel.Dock="Left"
                        Command="{Binding CloseCommand}"
                        ToolTip="{DynamicResource StatsOverlay.Back}">
                    <Path Data="M 12 19 L 5 12 L 12 5 M 19 12 L 5 12"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Width="16" Height="16"
                          Stretch="Uniform" />
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="{Binding ServerName}"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="240" />
                    <TextBlock Text="{Binding Host}"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="170"
                               VerticalAlignment="Center"
                               Margin="8,1,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsHostVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="*.*.*.*"
                               FontSize="11"
                               Foreground="{DynamicResource ObscuredTextBrush}"
                               VerticalAlignment="Center"
                               Margin="8,1,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsHostVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Width="22" Height="22" Padding="0" Margin="4,0,0,0"
                            Style="{StaticResource OverlayBackButton}"
                            Command="{Binding DataContext.ToggleHostVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="{Binding DataContext.HostVisibilityToolTip, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Width="14" Height="14"
                              Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="{StaticResource Icon.Eye}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsHostVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                            <Setter Property="Data" Value="{StaticResource Icon.EyeClosed}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </StackPanel>
            </DockPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="40,0,0,14">
                <ItemsControl ItemsSource="{Binding DataContext.SelectedStatsServer.MinuteBars, RelativeSource={RelativeSource AncestorType=Window}}"
                              VerticalAlignment="Center"
                              Margin="0,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="6" Height="14.4" CornerRadius="2"
                                    Background="{Binding Color}" Margin="1,0"
                                    ToolTip="{Binding Tooltip}"
                                    ToolTipService.InitialShowDelay="0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding CurrentAvailabilityText}"
                           Foreground="{Binding CurrentAvailabilityColor}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <TextBlock Text="{Binding CurrentLatencyText}"
                           Foreground="{Binding CurrentLatencyColor}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <UniformGrid Grid.Row="0" Grid.Column="1" Columns="24" Rows="1">
                    <TextBlock Text="0" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <TextBlock Text="6" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <TextBlock Text="12" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <TextBlock Text="18" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                    <Border />
                </UniformGrid>

                <ItemsControl Grid.Row="1" Grid.Column="0" ItemsSource="{Binding DateLabels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="18">
                                <TextBlock Text="{Binding}"
                                           FontSize="10"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="24" Rows="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="14"
                                    Margin="1"
                                    CornerRadius="2"
                                    ToolTip="{Binding Tooltip}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource HeatmapEmptyCellBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasData}" Value="True">
                                                <Setter Property="Background" Value="{Binding Color}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource StatsOverlay.TotalSuccess}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding TotalSuccessText}" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource StatsOverlay.TotalFailure}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding TotalFailureText}" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource StatsOverlay.TotalAvailability}" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding TotalAvailabilityText}" Foreground="{Binding TotalAvailabilityColor}" FontSize="15" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
