<UserControl x:Class="ServerPing.GUI.Views.ServerList.ServerListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="ServerListHost">
        <DataGrid x:Name="ServerDataGrid"
                  ItemsSource="{Binding Servers}"
                  SelectedItem="{Binding SelectedServer}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  AllowDrop="True"
                  HeadersVisibility="Column"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  RowHeight="38"
                  MinHeight="268"
                  MaxHeight="488"
                  AlternationCount="2"
                  Margin="0"
                  PreviewMouseLeftButtonDown="ServerDataGrid_PreviewMouseLeftButtonDown"
                  MouseMove="ServerDataGrid_MouseMove"
                  DragOver="ServerDataGrid_DragOver"
                  DragLeave="ServerDataGrid_DragLeave"
                  Drop="ServerDataGrid_Drop"
                  Sorting="ServerDataGrid_Sorting">
            <DataGrid.Columns>
                <!-- Status dot -->
                <DataGridTemplateColumn Width="28" CanUserResize="False">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="8" Height="8" Fill="{Binding StatusDotColor}"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="14,0,0,0"
                                     ToolTip="{Binding StatusTooltipText}"
                                     ToolTipService.InitialShowDelay="0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Name -->
                <DataGridTemplateColumn x:Name="NameColumn" Width="Auto" MaxWidth="160" SortMemberPath="Name">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="Cursor" Value="Hand" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="NameColumnHeaderText"
                                       Text="{DynamicResource Main.Name}"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}}" />
                            <TextBlock Text="{Binding DataContext.NameSortModeLabel, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                       Visibility="{Binding DataContext.IsNameSortModeLabelVisible, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVis}}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="10"
                                       Margin="5,1,0,0" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InlineEditTextBox}"
                                     GotFocus="IdentityTextBox_GotFocus"
                                     LostFocus="IdentityTextBox_LostFocus"
                                     KeyDown="IdentityTextBox_KeyDown"
                                     VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Availability -->
                <DataGridTemplateColumn x:Name="AvailabilityColumn" Header="{DynamicResource Main.Availability}" Width="Auto" MinWidth="52">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LastHourAvailabilityText}"
                                       Foreground="{Binding AvailabilityColor}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- MinuteState bars -->
                <DataGridTemplateColumn Width="Auto" MinWidth="84" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding MinuteBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="6" Height="24" CornerRadius="2"
                                                Background="{Binding Color}" Margin="1,0"
                                                ToolTip="{Binding Tooltip}"
                                                ToolTipService.InitialShowDelay="0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Last check -->
                <DataGridTextColumn x:Name="LastCheckColumn" Header="{DynamicResource Main.LastCheck}" Binding="{Binding LastPingTimeText}" Width="Auto" MinWidth="72">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Host/IP -->
                <DataGridTemplateColumn Width="*" MinWidth="126">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="HostColumnHeaderText"
                                       Text="{DynamicResource Main.Host}"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}}" />
                            <Button Width="22" Height="22" Padding="0" Margin="4,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{Binding DataContext.ToggleHostVisibilityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    ToolTip="{Binding DataContext.HostVisibilityToolTip, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent"
                                                            CornerRadius="4" Width="22" Height="22">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TitleBarHoverBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Path Stroke="{DynamicResource MutedTextBrush}"
                                      StrokeThickness="1.6" StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="14" Height="14" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource Icon.Eye}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsHostVisible, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False">
                                                    <Setter Property="Data" Value="{StaticResource Icon.EyeClosed}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBox x:Name="HostTextBox"
                                         Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                         GotFocus="IdentityTextBox_GotFocus"
                                         LostFocus="IdentityTextBox_LostFocus"
                                         KeyDown="IdentityTextBox_KeyDown"
                                         VerticalAlignment="Center">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource InlineEditTextBox}">
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding DataContext.IsHostVisible, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False" />
                                                        <Condition Binding="{Binding IsFocused, RelativeSource={RelativeSource Self}}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="Transparent" />
                                                    <Setter Property="CaretBrush" Value="Transparent" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock Text="*.*.*.*"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource ObscuredTextBrush}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding DataContext.IsHostVisible, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="False" />
                                                        <Condition Binding="{Binding IsFocused, ElementName=HostTextBox}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Latency -->
                <DataGridTemplateColumn x:Name="LatencyColumn" Header="{DynamicResource Main.Latency}" Width="Auto" MinWidth="58" CanUserResize="False">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LatencyText}"
                                       Foreground="{Binding LatencyColor}"
                                       FontWeight="SemiBold"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Actions -->
                <DataGridTemplateColumn x:Name="ActionsColumn" Header="{DynamicResource Main.Actions}" Width="Auto" MinWidth="80">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Command="{Binding DataContext.ToggleServerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Width="28" Height="28" Padding="0"
                                        Background="Transparent" BorderThickness="0" ToolTip="{DynamicResource Main.ToggleEnabled}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="Transparent"
                                                                CornerRadius="4" Width="28" Height="28">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TitleBarHoverBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource Icon.Power}"
                                          Stroke="{Binding EnableIconColor}"
                                          StrokeThickness="1.4" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="14" Height="14" Stretch="Uniform" />
                                </Button>

                                <Button Command="{Binding DataContext.RemoveServerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Width="28" Height="28" Padding="0" Margin="2,0,0,0"
                                        ToolTip="{DynamicResource Main.Delete}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="Transparent"
                                                                CornerRadius="4" Width="28" Height="28">
                                                            <Path x:Name="Ico" Data="{StaticResource Icon.Trash}"
                                                                  Stroke="{DynamicResource MutedTextBrush}"
                                                                  StrokeThickness="1.4" StrokeLineJoin="Round"
                                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                                  Width="14" Height="14" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Ico" Property="Stroke" Value="{DynamicResource DangerBrush}" />
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TitleBarHoverBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border x:Name="DropInsertionIndicator"
                Height="2"
                Margin="8,0,8,0"
                VerticalAlignment="Top"
                Background="{DynamicResource AccentBrush}"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DropInsertionIndicatorTransform" />
            </Border.RenderTransform>
        </Border>
    </Grid>
</UserControl>
