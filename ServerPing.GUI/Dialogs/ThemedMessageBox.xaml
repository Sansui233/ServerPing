<Window x:Class="ServerPing.GUI.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ServerPing"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
                <Grid Background="Transparent"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="14,0,0,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource TitleBarCloseButton}"
                            Margin="0,0,2,0"
                            Width="38"
                            Height="38"
                            Click="Close_Click">
                        <Path Data="{StaticResource Icon.X}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="13"
                              Height="13"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    Padding="18,18,18,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBorder"
                            Width="30"
                            Height="30"
                            CornerRadius="15"
                            VerticalAlignment="Top"
                            Margin="0,1,12,0">
                        <TextBlock x:Name="IconTextBlock"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Column="1"
                               x:Name="MessageTextBlock"
                               TextWrapping="Wrap"
                               LineHeight="19"
                               VerticalAlignment="Top" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <Button x:Name="OkButton"
                        HorizontalAlignment="Right"
                        MinWidth="76"
                        Padding="16,5"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Click="Ok_Click"
                        IsDefault="True"
                        IsCancel="True" />
            </Border>
        </Grid>
    </Border>
</Window>
