<Window x:Class="ServerPing.GUI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings.Title}"
        Height="440" Width="440"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
            <Grid Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource Settings.Title}" FontSize="13" FontWeight="SemiBold" Margin="14,0,0,0" />
                <Button Grid.Column="1" Style="{StaticResource TitleBarCloseButton}" Margin="0,0,2,0"
                        Width="38" Height="38" Click="Close_Click">
                    <Path Data="{StaticResource Icon.X}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6" StrokeLineJoin="Round"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Width="13" Height="13" Stretch="Uniform" />
                </Button>
            </Grid>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" Padding="18,16,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                <TextBlock Text="{DynamicResource Settings.Monitoring}" FontWeight="SemiBold" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Settings.PingInterval}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="PingIntervalTextBox" Margin="16,0,16,0"/>
                </Grid>

                

                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Settings.FailureThreshold}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="FailureThresholdTextBox"  Margin="16,0,16,0"/>
                </Grid>

                <CheckBox x:Name="OfflineNotificationCheckBox"
                          Content="{DynamicResource Settings.OfflineNotification}"
                          Margin="0,4,0,8" />

                <CheckBox x:Name="OfflineNotificationSoundCheckBox"
                          Content="{DynamicResource Settings.OfflineNotificationSound}"
                          Margin="0,0,0,8" />

                <TextBlock Text="{DynamicResource Settings.Appearance}" FontWeight="SemiBold" Margin="0,16,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Settings.Language}" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" x:Name="LanguageComboBox"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Code"
                              Margin="16,0,16,0" />
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MinWidth="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Settings.HibernateDuration}" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="HibernateDurationTextBox" Margin="16,0,16,0"/>
                </Grid>

                <CheckBox x:Name="SilentStartupCheckBox"
                          Content="{DynamicResource Settings.SilentStartup}"
                          Margin="0,4,0,8" />

                <CheckBox x:Name="LaunchAtStartupCheckBox"
                          Content="{DynamicResource Settings.LaunchAtStartup}"
                          Margin="0,0,0,18" />

                <TextBlock Text="{DynamicResource Settings.DataDirectory}" FontWeight="SemiBold" Margin="0,16,0,12" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <DockPanel LastChildFill="True" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Folder}"
                              Stroke="{DynamicResource MutedTextBrush}"
                              StrokeThickness="1.7" StrokeLineJoin="Round"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="16" Height="16" Stretch="Uniform"
                              Margin="0,0,7,0" DockPanel.Dock="Left" />
                        <TextBlock x:Name="DataDirectoryTextBlock"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                            <Button Grid.Column="1" Content="{DynamicResource Settings.Open}" Padding="12,5" Margin="16,0,16,0"
                            Click="OpenDataDirectory_Click" VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
                </Grid>

                <!-- Test notification — no wrapping border -->
                <Grid Margin="0,16,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.TestNotification}" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource Settings.TestNotificationDescription}"
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource Settings.Test}" Padding="12,5" Margin="16,0,16,0"
                            Click="TestNotification_Click" VerticalAlignment="Center" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.TestNotificationSound}" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource Settings.TestNotificationSoundDescription}"
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource Settings.Test}" Padding="12,5" Margin="16,0,16,0"
                            Click="TestNotificationSound_Click" VerticalAlignment="Center" />
                </Grid>

                <TextBlock x:Name="MessageTextBlock"
                           Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}" BorderThickness="0,1,0,0"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource Settings.Cancel}" Padding="16,5" Margin="0,0,8,0" Click="Close_Click" />
                    <Button Content="{DynamicResource Settings.Save}" Padding="16,5"
                            Background="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Click="Save_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
